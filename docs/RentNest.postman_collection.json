{
  "info": {
    "name": "RentNest API",
    "description": "Complete Postman collection for the RentNest backend. Admin credentials: admin@rentnest.com / Admin@123. Error format: { success, message, errorDetails }.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "tenantToken", "value": "" },
    { "key": "landlordToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "propertyId", "value": "" },
    { "key": "rentalRequestId", "value": "" },
    { "key": "paymentId", "value": "" },
    { "key": "stripePaymentIntentId", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "reviewId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Root",
          "request": { "method": "GET", "url": "{{baseUrl}}/" }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Tenant",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rahim Uddin\",\n  \"email\": \"rahim@example.com\",\n  \"password\": \"123456\",\n  \"role\": \"TENANT\",\n  \"phone\": \"01700000000\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Register Landlord",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Karim Sheikh\",\n  \"email\": \"karim@example.com\",\n  \"password\": \"123456\",\n  \"role\": \"LANDLORD\",\n  \"phone\": \"01812345678\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login Tenant",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"rahim@example.com\",\n  \"password\": \"123456\"\n}" },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login Landlord",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"karim@example.com\",\n  \"password\": \"123456\"\n}" },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@rentnest.com\",\n  \"password\": \"Admin@123\"\n}" },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "url": "{{baseUrl}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        { "name": "Get All Categories", "request": { "method": "GET", "url": "{{baseUrl}}/api/categories" } },
        {
          "name": "Create Category (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Apartment\"\n}" },
            "url": "{{baseUrl}}/api/categories"
          }
        },
        {
          "name": "Delete Category (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/categories/{{categoryId}}"
          }
        }
      ]
    },
    {
      "name": "Properties",
      "item": [
        { "name": "Get All Properties", "request": { "method": "GET", "url": "{{baseUrl}}/api/properties" } },
        { "name": "Get Property by ID", "request": { "method": "GET", "url": "{{baseUrl}}/api/properties/{{propertyId}}" } },
        {
          "name": "Get My Properties (Landlord)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{landlordToken}}" }],
            "url": "{{baseUrl}}/api/properties/my-properties"
          }
        },
        {
          "name": "Create Property (Landlord)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{landlordToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Cozy 2-Bed Apartment\",\n  \"description\": \"A clean and spacious apartment near the city center.\",\n  \"location\": \"Agrabad, Chittagong\",\n  \"price\": 15000,\n  \"bedrooms\": 2,\n  \"bathrooms\": 2,\n  \"amenities\": [\"wifi\", \"parking\"],\n  \"images\": [],\n  \"categoryId\": \"{{categoryId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/properties"
          }
        },
        {
          "name": "Update Property (Landlord)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{landlordToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"price\": 16000\n}" },
            "url": "{{baseUrl}}/api/properties/{{propertyId}}"
          }
        },
        {
          "name": "Delete Property (Landlord)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{landlordToken}}" }],
            "url": "{{baseUrl}}/api/properties/{{propertyId}}"
          }
        }
      ]
    },
    {
      "name": "Rental Requests",
      "item": [
        {
          "name": "Create Rental Request (Tenant)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propertyId\": \"{{propertyId}}\",\n  \"moveInDate\": \"2026-09-01\",\n  \"message\": \"I am interested in this property.\"\n}"
            },
            "url": "{{baseUrl}}/api/rentals"
          }
        },
        {
          "name": "Get My Requests (Tenant)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "url": "{{baseUrl}}/api/rentals/my-requests"
          }
        },
        {
          "name": "Get Landlord Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{landlordToken}}" }],
            "url": "{{baseUrl}}/api/rentals/landlord-requests"
          }
        },
        {
          "name": "Get Rental Request by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "url": "{{baseUrl}}/api/rentals/{{rentalRequestId}}"
          }
        },
        {
          "name": "Approve or Reject Request (Landlord)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{landlordToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"APPROVED\"\n}" },
            "url": "{{baseUrl}}/api/rentals/{{rentalRequestId}}"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment Intent (Tenant)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"rentalRequestId\": \"{{rentalRequestId}}\"\n}" },
            "url": "{{baseUrl}}/api/payments/create-intent"
          }
        },
        {
          "name": "Confirm Payment (Tenant)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"paymentIntentId\": \"{{stripePaymentIntentId}}\"\n}" },
            "url": "{{baseUrl}}/api/payments/confirm"
          }
        },
        {
          "name": "Get My Payments (Tenant)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "url": "{{baseUrl}}/api/payments"
          }
        },
        {
          "name": "Get Payment by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "url": "{{baseUrl}}/api/payments/{{paymentId}}"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Create Review (Tenant)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propertyId\": \"{{propertyId}}\",\n  \"rating\": 5,\n  \"comment\": \"Amazing property, very clean!\"\n}"
            },
            "url": "{{baseUrl}}/api/reviews"
          }
        },
        { "name": "Get Property Reviews", "request": { "method": "GET", "url": "{{baseUrl}}/api/reviews/property/{{propertyId}}" } },
        {
          "name": "Delete Review (Tenant)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "url": "{{baseUrl}}/api/reviews/{{reviewId}}"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/stats"
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/users"
          }
        },
        {
          "name": "Ban or Unban User",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"BANNED\"\n}" },
            "url": "{{baseUrl}}/api/admin/users/{{userId}}"
          }
        },
        {
          "name": "Get All Properties (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/properties"
          }
        },
        {
          "name": "Get All Rentals (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/rentals"
          }
        }
      ]
    }
  ]
}
